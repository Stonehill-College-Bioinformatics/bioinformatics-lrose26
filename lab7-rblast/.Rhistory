find_best_template <- function(query_seq, UK_subset) {
query_clean <- gsub("-", "", as.character(query_seq))
query_dna   <- DNAString(query_clean)
scores <- sapply(seq_along(UK_subset), function(i) {
aln <- pairwiseAlignment(
pattern  = query_dna,
subject  = UK_subset[[i]],
type     = "local",
scoreOnly = TRUE
)
aln
})
which.max(scores)
}
fill_from_template <- function(query_seq, template_seq) {
query_clean <- gsub("-", "", as.character(query_seq))
aln <- pairwiseAlignment(
pattern = DNAString(query_clean),
subject = template_seq,
type    = "local"
)
aln_query    <- strsplit(as.character(alignedPattern(aln)), "")[[1]]
aln_template <- strsplit(as.character(alignedSubject(aln)),  "")[[1]]
filled <- ifelse(aln_query == "-", aln_template, aln_query)
paste(filled, collapse = "")
}
filled_sequences <- DNAStringSet(lapply(seq_along(seqs), function(i) {
best_idx      <- find_best_template(seqs[[i]], UK_subset)
best_template <- UK_subset[[best_idx]]
filled <- fill_from_template(seqs[[i]], best_template)
filled
}))
