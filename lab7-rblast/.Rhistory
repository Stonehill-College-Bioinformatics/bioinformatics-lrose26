library(ape)
library(ggtree)
nj_tree <- nj(dist_matrix)
africa_ids <- grep("Africa", names(seqs), ignore.case = TRUE)
africa_seqs = seqs[africa_ids]
#subseqs <- subseq(africa_seqs, start = 20000, end = 50000)
dist_matrix <- stringDist(africa_seqs, method = "hamming")
nj_tree <- nj(dist_matrix)
plot(nj_tree, main="Neighbor-Joining Tree") #Simpler method without ggtree
ggtree(nj_tree) +
geom_tiplab() +
ggplot2::xlim(0, 15000) +
theme_tree2()
