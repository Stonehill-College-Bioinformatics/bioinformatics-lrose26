mouse_seqs = readDNAStringSet("C:\Users\laure\OneDrive\Documents\GitHub\bioinformatics-lrose26\lab7-rblast\MouseClustalData.fa")
mouse_seqs = readDNAStringSet("C:/Users/laure/OneDrive/Documents/GitHub/bioinformatics-lrose26/lab7-rblast/MouseClustalData.fa")
mouse_dist = stringDist(mouse_seqs, method = "hamming")
print(as.matrix(mouse_dist))
mouse_nj = nj(mouse_dist)
ggtree(mouse_nj) +
geom_tiplab() +
ggplot2::xlim(0, 15) +
theme_tree2() +
ggtitle("Neighbor-Joining Tree of 5 Mouse Haplotypes")
seq_matrix = do.call(rbind, strsplit(as.character(mouse_seqs), ""))
no_gap_cols = apply(seq_matrix, 2, function(col) !any(col == "-"))
filtered_matrix = seq_matrix[, no_gap_cols]
filtered_seqs = apply(filtered_matrix, 1, paste, collapse = "")
filtered_dna = DNAStringSet(filtered_seqs)
names(filtered_dna) = names(mouse_seqs)
filtered_dist = stringDist(filtered_dna, method = "hamming")
print(as.matrix(filtered_dist))
filtered_nj <- nj(filtered_dist)
ggtree(filtered_nj) +
geom_tiplab() +
ggplot2::xlim(0, 10) +
theme_tree2() +
ggtitle("NJ Tree (Indel Sites Removed)")
